<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE channel [
  <!ENTITY panel.top.position  "0">
  <!ENTITY panel.bottom.position "1">
]>
<channel name="xfce4-panel" version="1.0">
  <!-- ============================================================
       Alicia Desktop Environment - XFCE4 Panel Configuration
       Proyecto Tomorrow - Enterprise Linux Desktop for Android
       ============================================================ -->

  <property name="panels" type="uint" value="2">
